generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String     @id @default(cuid())
  whatsappNumber  String     @unique
  email           String?    @unique
  name            String?
  vehiclePlate    String?
  city            String?
  workApps                  Json     @default("[]")
  subscriptionPaymentMethod String   @default("PIX")
  workDays                  Json     @default("[1, 2, 3, 4, 5, 6]")
  status          UserStatus @default(TRIAL)
  trialEndsAt     DateTime?
  subscribedAt    DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  currentOdometerKm Decimal? @db.Decimal(10, 1)
  costs             CostConfig?
  deliveries        Delivery[]
  shifts            Shift[]
  goals             Goal[]
  payments          Payment[]
  routes            Route[]
  fuelRefuels       FuelRefuel[]
  odometerReadings  OdometerReading[]
  activityLogs      ActivityLog[]

  referredByAffiliateId String?
  referredByAffiliate   Affiliate? @relation(fields: [referredByAffiliateId], references: [id], onDelete: SetNull)
  affiliateCouponCode   String?
  referredAt            DateTime?
  asaasCustomerId       String?    @unique

  @@index([whatsappNumber])
  @@index([referredByAffiliateId])
}

model Affiliate {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  active    Boolean  @default(true)
  phone     String?
  email     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  referrals User[]

  @@index([code])
  @@index([active])
}

enum ActivityCategory {
  PROFILE
  COSTS
  GOAL
  DELIVERY
  FUEL
  ODOMETER
  SHIFT
}

enum ActivityAction {
  CREATED
  UPDATED
  DELETED
}

model ActivityLog {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  category  ActivityCategory
  action    ActivityAction
  title     String
  changes   Json             @default("[]")
  entityId  String?
  source    String           @default("app")
  createdAt DateTime         @default(now())

  @@index([userId, createdAt])
}

enum UserStatus {
  TRIAL
  ACTIVE
  PAUSED
  CANCELED
}

model CostConfig {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fuelPricePerLiter Decimal  @default(6.00) @db.Decimal(10, 2)
  kmPerLiter        Decimal  @default(35.00) @db.Decimal(10, 2)
  maintenancePerKm  Decimal  @default(0.15) @db.Decimal(10, 4)
  dailyFoodCost     Decimal  @default(25.00) @db.Decimal(10, 2)
  otherDailyCost    Decimal  @default(0.00) @db.Decimal(10, 2)
  updatedAt         DateTime @updatedAt
}

model Delivery {
  id              String         @id @default(cuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  source          DeliverySource
  grossValue      Decimal        @db.Decimal(10, 2)
  distanceKm      Decimal?       @db.Decimal(10, 2)
  durationMin     Int?
  originName      String?
  destinationAddr String?
  destinationLat  Float?
  destinationLng  Float?
  proofPhotoUrl   String?
  proofLat        Float?
  proofLng        Float?
  proofAt         DateTime?
  rawInput        Json
  parsedAt        DateTime       @default(now())
  occurredAt      DateTime       @default(now())

  @@index([userId, occurredAt])
}

enum DeliverySource {
  IFOOD
  NINETY_NINE
  RAPPI
  PARTICULAR
  OTHER
}

model Shift {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  startedAt DateTime
  endedAt   DateTime?
  startKm   Decimal?  @db.Decimal(10, 2)
  endKm     Decimal?  @db.Decimal(10, 2)

  @@index([userId, startedAt])
}

model Goal {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  period      GoalPeriod
  targetValue Decimal    @db.Decimal(10, 2)
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now())

  @@index([userId, period, active])
}

enum GoalPeriod {
  DAILY
  WEEKLY
  MONTHLY
}

model Route {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  addresses      Json
  optimizedOrder Json
  totalKm        Decimal  @db.Decimal(10, 2)
  totalMin       Int
  createdAt      DateTime @default(now())

  @@index([userId, createdAt])
}

model Payment {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  asaasChargeId String?       @unique
  status        PaymentStatus
  amount        Decimal       @db.Decimal(10, 2)
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model WhatsAppMessage {
  id          String   @id @default(cuid())
  userId      String?
  fromNumber  String
  messageType String
  rawContent  Json
  processedAs String?
  receivedAt  DateTime @default(now())

  @@index([fromNumber, receivedAt])
}

model FuelRefuel {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalAmount     Decimal  @db.Decimal(10, 2)
  liters          Decimal  @db.Decimal(10, 3)
  pricePerLiter   Decimal  @db.Decimal(10, 3)
  receiptPhotoUrl String?
  rawInput        Json
  occurredAt      DateTime @default(now())

  @@index([userId, occurredAt])
}

model OdometerReading {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  odometerKm Decimal  @db.Decimal(10, 1)
  photoUrl   String?
  rawInput   Json
  recordedAt DateTime @default(now())

  @@index([userId, recordedAt])
}

model AuthCode {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone, expiresAt])
}

model AdminAccount {
  id           String   @id @default("primary")
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
