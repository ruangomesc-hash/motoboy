# Cole estas variáveis em: Vercel → Project → Settings → Environment Variables
# Marque: Production, Preview e Development (onde fizer sentido)
# Marque também "Expose to Build" para DATABASE_URL e DIRECT_URL

# --- Supabase (obrigatório) ---
DATABASE_URL=postgresql://postgres.[REF]:[SENHA]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres.[REF]:[SENHA]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres

# --- App (obrigatório) — use seu domínio .vercel.app ou customizado ---
NEXTAUTH_URL=https://motocopiloto.vercel.app
APP_URL=https://motocopiloto.vercel.app
NEXT_PUBLIC_APP_URL=https://motocopiloto.vercel.app

# --- Auth (obrigatório) ---
NEXTAUTH_SECRET=
JWT_SECRET=

# --- Admin (obrigatório para /admin) ---
ADMIN_EMAIL=
# Senha temporária até salvar no painel (ou use só após migrations)
ADMIN_PASSWORD=

# --- Fase inicial: entrar sem código WhatsApp (desligar quando Evolution estiver ativo) ---
ALLOW_SKIP_AUTH_CODE=true
NEXT_PUBLIC_ALLOW_SKIP_AUTH_CODE=true

# --- Demo / admin dev (opcional) ---
NEXT_PUBLIC_ALLOW_DEMO_LOGIN=true
NEXT_PUBLIC_ALLOW_ADMIN_DEV_LOGIN=false
NEXT_PUBLIC_ENABLE_SOCKET=false

# --- NÃO definir em produção (API roda no mesmo domínio) ---
# API_URL=

# --- Asaas (gateway de pagamento — recomendado em produção) ---
# Sandbox: https://sandbox.asaas.com | Produção: https://www.asaas.com
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=
ASAAS_SANDBOX=true

# --- Opcional ---
# REDIS_URL=rediss://default:xxx@xxx.upstash.io:6379
# RUN_WHATSAPP_WORKER=false
# EVOLUTION_API_URL=
# EVOLUTION_API_KEY=
# EVOLUTION_INSTANCE=
# OPENAI_API_KEY=
# GOOGLE_MAPS_API_KEY=
