# =============================================================================
# Motocopiloto — variáveis de ambiente (local + Vercel + Supabase)
# Copie para .env na raiz e preencha. Na Vercel, cadastre as mesmas chaves.
# =============================================================================

# --- Supabase (PostgreSQL) ---
# Transaction pooler (porta 6543) — use em DATABASE_URL na Vercel e em produção
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
# Conexão direta (porta 5432) — migrations e pnpm db:push (local/CI)
DIRECT_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres

# Local (Docker): descomente e comente Supabase acima
# DATABASE_URL=postgresql://postgres:senha@localhost:5432/motoboy
# DIRECT_URL=postgresql://postgres:senha@localhost:5432/motoboy

# --- Redis (opcional: fila WhatsApp / worker) ---
# Vercel: use Upstash — https://upstash.com — URL rediss://...
# Sem Redis: login e CRUD funcionam via Supabase; worker WhatsApp fica desligado
REDIS_URL=redis://localhost:6379

# --- URLs do app ---
# Produção Vercel (substitua pelo seu domínio)
APP_URL=https://seu-app.vercel.app
NEXTAUTH_URL=https://seu-app.vercel.app
# Local
# APP_URL=http://localhost:3002
# NEXTAUTH_URL=http://localhost:3002

# API: em produção na Vercel deixe vazio (usa /api/backend no mesmo domínio)
API_URL=http://localhost:3001
# NEXT_PUBLIC_API_URL só se API estiver em outro host (ex.: worker + socket)
# NEXT_PUBLIC_ENABLE_SOCKET=true

# --- Auth ---
NEXTAUTH_SECRET=gerar-com-openssl-rand-base64-32
JWT_SECRET=outro-secret-aleatorio-min-16-chars

# Painel admin (/admin)
ADMIN_EMAIL=admin@motocopiloto.com.br
ADMIN_PASSWORD=troque-por-uma-senha-forte-min-8

# Fase inicial: cadastro completo e login sem código WhatsApp (desligar quando Evolution ativo)
ALLOW_SKIP_AUTH_CODE=true
NEXT_PUBLIC_ALLOW_SKIP_AUTH_CODE=true

# Web: preview admin / demo (opcional)
NEXT_PUBLIC_ALLOW_ADMIN_DEV_LOGIN=false
NEXT_PUBLIC_ALLOW_DEMO_LOGIN=false

# --- WhatsApp (Evolution API) — opcional ---
EVOLUTION_API_URL=https://evolution.seuservidor.com
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=motoboy
EVOLUTION_BOT_NUMBER=5511999999999
# Worker de fila (requer Redis). Em Vercel serverless deixe false
RUN_WHATSAPP_WORKER=false

# --- Asaas (gateway de pagamento) ---
# Sandbox: https://sandbox.asaas.com | Produção: https://www.asaas.com
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=
ASAAS_SANDBOX=true

# --- OpenAI / Maps — opcional ---
OPENAI_API_KEY=
# Geocoding API + Directions API (roteirizador e mapas)
GOOGLE_MAPS_API_KEY=
