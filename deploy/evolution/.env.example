# Copie para .env na VPS: cp .env.example .env && nano .env

# Chave do painel Evolution (mesma na Vercel: EVOLUTION_API_KEY)
EVOLUTION_API_KEY=troque-por-uma-chave-forte

# URL pública com HTTPS (depois do Caddy)
EVOLUTION_SERVER_URL=https://evo.motocopiloto.com.br

# Senha do Postgres interno (só na VPS)
EVOLUTION_PG_PASSWORD=troque-senha-postgres-interno
