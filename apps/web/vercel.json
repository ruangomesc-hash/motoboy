{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "pnpm vercel-build",
  "installCommand": "cd ../.. && pnpm install --no-frozen-lockfile",
  "regions": ["gru1"],
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },
  "functions": {
    "src/app/api/backend/[...path]/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "src/app/api/auth/[...nextauth]/route.ts": {
      "maxDuration": 30
    }
  }
}
